{
  "name": "@shelviahq/context-pack",
  "version": "1.0.0",
  "description": "Validate, render, and export Context Packs — portable, reviewed project context for AI tools.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "shelvia-context-pack": "bin/cli.mjs"
  },
  "files": [
    "dist",
    "schema",
    "bin"
  ],
  "keywords": [
    "context-pack",
    "ai",
    "agents",
    "prompt",
    "handoff",
    "json-schema",
    "cli"
  ],
  "homepage": "https://github.com/Evan14-7/shelvia-context-kit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Evan14-7/shelvia-context-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Evan14-7/shelvia-context-kit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "pretest": "npm run build",
    "test": "node --test",
    "validate": "node scripts/validate-examples.mjs",
    "validate:examples": "node scripts/validate-examples.mjs",
    "check:json": "node scripts/check-json.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  }
}
